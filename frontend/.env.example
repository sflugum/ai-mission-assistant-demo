# Production (Vercel): set to the deployed Render backend URL,
#   e.g. VITE_API_URL=https://ai-mission-assistant-demo.onrender.com
# Local dev (host `npm run dev` or `docker compose up`): leave blank.
# When blank, the frontend posts to `/analyze` and Vite proxies to the backend
# (target controlled by VITE_PROXY_TARGET in vite.config.js).
VITE_API_URL=
