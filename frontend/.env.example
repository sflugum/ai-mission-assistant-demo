# Host `npm run dev` only. For Docker Compose, use repo-root .env (see /.env.example).
# VITE_* vars are exposed to the browser bundle — use anon key only, never service role.

# Production (Vercel): set to the deployed Render backend URL
# VITE_API_URL=https://ai-mission-assistant-demo.onrender.com
VITE_API_URL=

# Vite dev proxy (host npm dev only; Docker sets http://backend:3001 in compose)
# VITE_PROXY_TARGET=http://localhost:3001

# Must match the Supabase project your backend writes to (same as backend SUPABASE_URL host)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
