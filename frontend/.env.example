# Backend API origin. Blank locally (Vite proxies /analyze and /api).
# On Vercel, set to the Render URL (e.g. https://ai-mission-assistant-demo.onrender.com).
VITE_API_URL=

# Override if backend uses a non-default port (e.g. PORT=3002 in backend/.env).
# VITE_PROXY_TARGET=http://localhost:3002

# Vercel Serverless Function for decoupled API
GOOGLE_GENERATIVE_AI_API_KEY=your_api_key_here