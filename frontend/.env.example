# Production (Vercel): set to the deployed Render backend URL,
#   e.g. VITE_API_URL=https://ai-mission-assistant-demo.onrender.com
# Local dev (host `npm run dev` or `docker compose up`): leave blank.
# When blank, the frontend posts to `/analyze` and Vite proxies to the backend
# (target controlled by VITE_PROXY_TARGET in vite.config.js).
VITE_API_URL=
# Vite proxy target (server-side hop only):
#   Host `npm run dev`: http://localhost:3001 (or match backend PORT / .port_config.json)
#   Docker Compose frontend service: http://backend:3001 (set in docker-compose.yaml; do not use localhost inside the container)
# VITE_PROXY_TARGET=http://localhost:3001

# Supabase (browser): must be reachable from your machine's browser, not from inside Docker.
#   Local Supabase CLI: http://127.0.0.1:54321 (must match where POST /missions writes — see backend SUPABASE_URL)
#   docker compose up overrides these to local CLI values even if this file points at production.
#   Do not use host.docker.internal here — the React app runs in the browser on the host.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
