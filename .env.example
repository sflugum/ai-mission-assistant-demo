# Docker Compose: copy to .env at repo root (gitignored).
# Fill keys from: npx supabase status -o env
# Run order: npx supabase start → docker compose up --build
# Host npm run dev uses backend/.env and frontend/.env instead (see README).

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend 
SUPABASE_URL_DOCKER=http://host.docker.internal:54321
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL_DOCKER=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# Browser + Vite 
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Leave blank for Docker/local Vite proxy; set only for production (Render URL).
VITE_API_URL=
# Compose also sets VITE_PROXY_TARGET=http://backend:3001 on the frontend service
VITE_PROXY_TARGET=http://backend:3001
