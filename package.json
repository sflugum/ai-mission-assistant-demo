{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ai-mission-assistant-demo",
  "version": "0.1.0",
  "private": true,
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "description": "AI Mission Assistant demo — React (Vite) frontend, Express backend, Neon (Postgres).",
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "test": "npm run test:run",
    "test:run": "npm run test:run --workspace frontend",
    "test:e2e": "npm run test:e2e --workspace frontend",
    "dev": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "start:backend": "npm run start --workspace backend",
    "start": "node backend/server.js",
    "migrate": "node scripts/migrate.js"
  },
  "devDependencies": {
    "@types/node": "^25.7.0"
  },
  "dependencies": {
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "^1.29.0"
  }
}
