{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ai-mission-assistant-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "repo:types": "npm run types:generate --prefix ..",
    "repo:test": "npm run test:run --prefix ..",
    "repo:test:e2e": "npm run test:e2e --prefix ..",
    "repo:db:test": "npm run db:test --prefix .."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "cors": "^2.8.5",
    "express-async-handler": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
