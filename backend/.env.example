# Docker Compose: copy to .env at repo root (gitignored).
# Run order: docker compose up --build
# Host npm run dev uses backend/.env and frontend/.env instead (see README).

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend Database 
# Replace this with your actual Neon connection string in your local .env
DATABASE_URL=postgresql://<user>:<password>@<neon_host>/<dbname>?sslmode=require

# Browser + Vite 
# Leave blank for Docker/local Vite proxy; set only for production (Zeabur URL).
VITE_API_URL=
# Compose also sets VITE_PROXY_TARGET=http://backend:3001 on the frontend service
VITE_PROXY_TARGET=http://backend:3001