GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
# If you see EADDRINUSE (often Docker already maps 3001), use another port and set VITE_PROXY_TARGET in frontend/.env
PORT=3001
#
# CORS: browser Origin header (not container hostnames). docker-compose.yaml sets ALLOWED_ORIGINS.
# Host dev: http://localhost:5173
#
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Configuration
# Host `npm run dev`: http://127.0.0.1:54321
# Docker backend container: http://host.docker.internal:54321 (set in docker-compose.yaml)
# Production (Render): your hosted Supabase project URL.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_public_anon_key_for_client_side
SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key_for_backend_only

# Direct Postgres connection string (currently unused by the app — reserved for
# raw-pg tooling, scripts, or future migration utilities).
# Local dev (Docker compose overrides this):
#   DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
# Production: pooled/direct connection string from your Supabase project.
DATABASE_URL=your_postgres_connection_string

